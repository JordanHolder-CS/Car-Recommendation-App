{
  "expo": {
    "name": "Car_Recommender",
    "slug": "Car_Recommender",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "REDACTED "
      }
    },
    "android": {
      "package": "com.anonymous.Car_Recommender",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "REDACTED "
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-font",
        {
          "fonts": [
            "./src/ui/Fonts/PP_Mori_v2.6/otf/PPMori-Regular.otf",
            "./src/ui/Fonts/PP_Mori_v2.6/otf/PPMori-Black.otf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "PP Mori",
                "fontDefinitions": [
                  {
                    "path": "./src/ui/Fonts/PP_Mori_v2.6/otf/PPMori-Regular.otf",
                    "weight": 400
                  },
                  {
                    "path": "./src/ui/Fonts/PP_Mori_v2.6/otf/PPMori-Black.otf",
                    "weight": 800
                  }
                ]
              }
            ]
          }
        }
      ]
    ]
  }
}
